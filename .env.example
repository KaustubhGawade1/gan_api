# GAN Backend API Configuration

# Debug mode (set to True for development)
DEBUG=False

# API settings
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# Device: 'cuda' for GPU, 'cpu' for CPU
# If not set, automatically defaults to 'cuda' if available, else 'cpu'
DEVICE=cuda

# Model weights path
# Defaults to ./weights/generator.pth if not set
MODEL_WEIGHTS_PATH=./weights/generator.pth

# CLIP model (HuggingFace model ID)
CLIP_MODEL_NAME=openai/clip-vit-base-patch32

# Generation settings
# Image output size (in pixels, square)
IMAGE_SIZE=256

# JPEG quality (1-100, higher = better quality & larger file size)
JPEG_QUALITY=95

# Noise dimension for generator
NOISE_DIM=100

# Number of classes (for conditional GAN)
NUM_CLASSES=1000
